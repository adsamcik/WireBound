<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:WireBound.Avalonia.Controls"
             xmlns:vm="using:WireBound.Avalonia.ViewModels"
             x:Class="WireBound.Avalonia.Views.AppsView"
             x:DataType="vm:AppsViewModel"
             Background="{StaticResource BackgroundBrush}"
             AutomationProperties.Name="Apps and processes">

    <!--
        This page deliberately has no outer vertical ScrollViewer. The process
        table occupies the final star-sized row, giving its ListBox a real
        viewport so Avalonia can virtualize and recycle its row containers.
    -->
    <Grid Margin="24"
          RowDefinitions="Auto, Auto, Auto, *"
          RowSpacing="16">

        <!-- Page heading and concise collection state. -->
        <Grid ColumnDefinitions="*, Auto"
              ColumnSpacing="16">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Apps &amp; processes" Classes="PageTitle" />
                    <Border Background="{StaticResource SuccessBgTintBrush}"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsPageActive}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Classes="StatusDot" Width="7" Height="7" />
                            <TextBlock Text="LIVE"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource BorderSubtleBrush}"
                            CornerRadius="999"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            IsVisible="{Binding !IsPageActive}">
                        <TextBlock Text="PAUSED"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Live CPU, memory, and network usage by running process"
                           Classes="Subtitle" />
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="SubtleCard"
                    Padding="14,10"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Process telemetry status">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource SuccessBrush}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding HasNetworkData}" />
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource MutedTextBrush}"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !HasNetworkData}" />
                    <StackPanel Spacing="1">
                        <TextBlock Text="Network telemetry"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding HasNetworkData}" />
                        <TextBlock Text="Waiting for network telemetry"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding !HasNetworkData}" />
                        <TextBlock Text="{Binding LastUpdatedLabel}" Classes="Caption" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Keep the summary intentionally compact: it offers context without
             taking vertical room away from the virtualized process list. -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*, *, *, *, *"
              ColumnSpacing="12">
            <Border Grid.Column="0" Classes="CompactCard" Padding="14,12">
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbEntityApp" Width="14" Height="14" />
                        <TextBlock Text="PROCESSES" Classes="MetricLabel" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding ProcessCount}"
                               FontSize="22"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding ProcessCount}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="CompactCard" Padding="14,12">
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbEntityCpu" Width="14" Height="14" />
                        <TextBlock Text="TOTAL CPU" Classes="MetricLabel" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalCpu}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource CpuBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding TotalCpu}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="CompactCard" Padding="14,12">
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbEntityMemory" Width="14" Height="14" />
                        <TextBlock Text="TOTAL MEMORY" Classes="MetricLabel" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalMemory}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource MemoryBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding TotalMemory}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="CompactCard" Padding="14,12">
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbMetricDownload" Width="14" Height="14" />
                        <TextBlock Text="DOWNLOAD" Classes="MetricLabel" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalDownloadSpeed}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource DownloadBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding TotalDownloadSpeed}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Classes="CompactCard" Padding="14,12">
                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbMetricUpload" Width="14" Height="14" />
                        <TextBlock Text="UPLOAD" Classes="MetricLabel" FontSize="11" />
                    </StackPanel>
                    <TextBlock Text="{Binding TotalUploadSpeed}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource UploadBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding TotalUploadSpeed}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- A single, low-chrome toolbar keeps common actions in reach without
             turning the live monitor into a filter-heavy historical report. -->
        <Border Grid.Row="2" Classes="SubtleCard" Padding="12">
            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="12">
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        MinHeight="40"
                        Padding="12,0">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <controls:WbIcon IconKey="WbActionSearch" Width="16" Height="16" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText}"
                                 PlaceholderText="Search process name, PID, or path…"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 VerticalAlignment="Center"
                                 MinWidth="220"
                                 AutomationProperties.Name="Search processes"
                                 AutomationProperties.HelpText="Filter running processes by display name, process name, process ID, or executable path" />
                    </Grid>
                </Border>

                <CheckBox Grid.Column="1"
                          IsChecked="{Binding ShowSystemProcesses}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Show system processes"
                          AutomationProperties.HelpText="Include operating system and background processes in the process list">
                    <TextBlock Text="Show system" FontSize="13" VerticalAlignment="Center" />
                </CheckBox>

                <Button Grid.Column="2"
                        Classes="Secondary ToolbarButton"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        AutomationProperties.Name="Refresh process usage"
                        AutomationProperties.HelpText="Take a new snapshot of process CPU, memory, and network usage">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <controls:WbIcon IconKey="WbActionRefresh" Width="14" Height="14" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Fixed table header + star-sized body. The inner horizontal scroller
             only handles narrow windows; vertical scrolling stays on ListBox. -->
        <Border Grid.Row="3"
                Classes="Card"
                Padding="0"
                MinHeight="0"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto, *" MinHeight="0">
                <Grid Margin="20,16,20,12" ColumnDefinitions="*, Auto" ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="{StaticResource AccentBgTintBrush}"
                                Width="32" Height="32" CornerRadius="8">
                            <controls:WbIcon IconKey="WbEntityApp" Width="16" Height="16" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Running processes" Classes="SectionHeader" FontSize="16" />
                            <TextBlock Text="Sorted live snapshot" Classes="Caption" />
                        </StackPanel>
                    </StackPanel>
                    <ProgressBar Grid.Column="1"
                                 IsIndeterminate="True"
                                 Width="48"
                                 Height="4"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsLoading}"
                                 AutomationProperties.Name="Refreshing process usage" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              MinHeight="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid MinWidth="950"
                          MinHeight="0"
                          RowDefinitions="Auto, *">
                        <!-- Column widths are repeated by the item template so
                             metric values stay aligned while the list recycles. -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BorderSubtleBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="0,1,0,1"
                                Padding="20,10">
                            <Grid ColumnDefinitions="*, 90, 130, 120, 120, 125"
                                  ColumnSpacing="12">
                                <Button Classes="Ghost"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ToggleSortCommand}"
                                        CommandParameter="{x:Static vm:ProcessUsageSortColumn.Name}"
                                        AutomationProperties.Name="Sort processes by name"
                                        AutomationProperties.HelpText="Sort the running process table by application or process name">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="PROCESS" Classes="MetricLabel" FontSize="11" />
                                        <TextBlock Text="{Binding NameSortGlyph}" Classes="MetricLabel" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Classes="Ghost"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ToggleSortCommand}"
                                        CommandParameter="{x:Static vm:ProcessUsageSortColumn.Cpu}"
                                        AutomationProperties.Name="Sort processes by CPU"
                                        AutomationProperties.HelpText="Sort the running process table by current CPU usage">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="CPU" Classes="MetricLabel" FontSize="11" />
                                        <TextBlock Text="{Binding CpuSortGlyph}" Classes="MetricLabel" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Classes="Ghost"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ToggleSortCommand}"
                                        CommandParameter="{x:Static vm:ProcessUsageSortColumn.Memory}"
                                        AutomationProperties.Name="Sort processes by memory"
                                        AutomationProperties.HelpText="Sort the running process table by physical memory usage">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="MEMORY" Classes="MetricLabel" FontSize="11" />
                                        <TextBlock Text="{Binding MemorySortGlyph}" Classes="MetricLabel" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3"
                                        Classes="Ghost"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ToggleSortCommand}"
                                        CommandParameter="{x:Static vm:ProcessUsageSortColumn.Download}"
                                        AutomationProperties.Name="Sort processes by download speed"
                                        AutomationProperties.HelpText="Sort the running process table by current download speed">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="DOWNLOAD" Classes="MetricLabel" FontSize="11" />
                                        <TextBlock Text="{Binding DownloadSortGlyph}" Classes="MetricLabel" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4"
                                        Classes="Ghost"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ToggleSortCommand}"
                                        CommandParameter="{x:Static vm:ProcessUsageSortColumn.Upload}"
                                        AutomationProperties.Name="Sort processes by upload speed"
                                        AutomationProperties.HelpText="Sort the running process table by current upload speed">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="UPLOAD" Classes="MetricLabel" FontSize="11" />
                                        <TextBlock Text="{Binding UploadSortGlyph}" Classes="MetricLabel" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Column="5"
                                           Text="SESSION"
                                           Classes="MetricLabel"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" MinHeight="0">
                            <ListBox ItemsSource="{Binding ProcessItems}"
                                     SelectionMode="Single"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MinHeight="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.Name="Running processes"
                                     AutomationProperties.HelpText="Virtualized list of processes with live CPU, memory, and network usage">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected Border.ProcessRow">
                                        <Setter Property="Background" Value="{StaticResource SelectionBgBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProcessUsageDisplayItem">
                                        <Border Classes="ProcessRow"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="20,8"
                                                Height="64"
                                                ToolTip.Tip="{Binding ExecutablePath}"
                                                AutomationProperties.Name="{Binding DisplayName}"
                                                AutomationProperties.HelpText="{Binding ExecutablePath}">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="{StaticResource FlyoutItemHoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                                </Style>
                                            </Border.Styles>
                                            <Grid ColumnDefinitions="*, 90, 130, 120, 120, 125"
                                                  ColumnSpacing="12">
                                                <!-- Identity remains left-aligned and wide enough to make the
                                                     process list useful even on a narrow monitor. -->
                                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                                    <Border Width="36" Height="36"
                                                            CornerRadius="9"
                                                            Background="{StaticResource AccentBgTintBrush}">
                                                        <controls:WbIcon IconKey="WbEntityApp" Width="18" Height="18" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="2">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding ProcessName}"
                                                                       Classes="Caption"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="180" />
                                                            <TextBlock Text="•" Classes="Caption" />
                                                            <TextBlock Text="{Binding ProcessId, StringFormat='PID {0}'}"
                                                                       Classes="Caption" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Grid.Column="2"
                                                            Background="{StaticResource BorderSubtleBrush}"
                                                            CornerRadius="999"
                                                            Padding="7,2"
                                                            VerticalAlignment="Center"
                                                            IsVisible="{Binding IsSystemProcess}">
                                                        <TextBlock Text="SYSTEM"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Spacing="1">
                                                    <TextBlock Text="{Binding CpuDisplay}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource CpuBrush}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="Awaiting sample"
                                                               Classes="Caption"
                                                               FontSize="10"
                                                               HorizontalAlignment="Right"
                                                               IsVisible="{Binding !HasCpuSample}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding MemoryDisplay}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MemoryBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding MemoryDisplay}" />

                                                <StackPanel Grid.Column="3"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Spacing="1">
                                                    <TextBlock Text="{Binding DownloadDisplay}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource DownloadBrush}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="No telemetry"
                                                               Classes="Caption"
                                                               FontSize="10"
                                                               HorizontalAlignment="Right"
                                                               IsVisible="{Binding !HasNetworkStats}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Spacing="1">
                                                    <TextBlock Text="{Binding UploadDisplay}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource UploadBrush}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="No telemetry"
                                                               Classes="Caption"
                                                               FontSize="10"
                                                               HorizontalAlignment="Right"
                                                               IsVisible="{Binding !HasNetworkStats}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding SessionTotalDisplay}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding SessionTotalDisplay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- The empty state is an overlay, preserving the finite list
                                 viewport whether data has arrived or not. -->
                            <Border Background="{StaticResource CardBrush}"
                                    IsVisible="{Binding !HasVisibleProcesses}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="10"
                                            MaxWidth="380">
                                    <Border Width="56" Height="56"
                                            CornerRadius="14"
                                            Background="{StaticResource AccentBgTintBrush}"
                                            HorizontalAlignment="Center">
                                        <controls:WbIcon IconKey="WbEntityApp" Width="26" Height="26" />
                                    </Border>
                                    <TextBlock Text="No processes to show"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Processes appear while this page is active. Try clearing the search or showing system processes."
                                               Classes="Subtitle"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
