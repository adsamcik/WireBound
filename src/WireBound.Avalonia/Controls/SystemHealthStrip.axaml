<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:WireBound.Avalonia.Controls"
             x:Class="WireBound.Avalonia.Controls.SystemHealthStrip"
             x:DataType="controls:SystemHealthStrip"
             AutomationProperties.Name="System Health Indicator"
             Focusable="True"
             IsTabStop="True">

    <Border Classes="CompactCard" Padding="10,5">
        <StackPanel Orientation="Horizontal" Spacing="0">

            <!-- CPU Metric -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding CpuGaugeColor, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}" />
                <TextBlock FontSize="12" VerticalAlignment="Center">
                    <Run Text="CPU" Foreground="{StaticResource SecondaryTextBrush}" />
                    <Run Text="{Binding CpuPercentText, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}"
                         FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                </TextBlock>
            </StackPanel>

            <!-- Separator -->
            <Border Width="1"
                    Background="{StaticResource DividerBrush}"
                    Margin="12,3"
                    VerticalAlignment="Stretch" />

            <!-- RAM Metric -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding MemoryGaugeColor, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}" />
                <TextBlock FontSize="12" VerticalAlignment="Center">
                    <Run Text="RAM" Foreground="{StaticResource SecondaryTextBrush}" />
                    <Run Text="{Binding MemoryPercentText, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}"
                         FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                </TextBlock>
            </StackPanel>

            <!-- GPU Section (conditionally visible) -->
            <StackPanel Orientation="Horizontal"
                        IsVisible="{Binding ShowGpu, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}">
                
                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource DividerBrush}"
                        Margin="12,3"
                        VerticalAlignment="Stretch" />

                <!-- GPU Metric -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding GpuGaugeColor, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}" />
                    <TextBlock FontSize="12" VerticalAlignment="Center">
                        <Run Text="GPU" Foreground="{StaticResource SecondaryTextBrush}" />
                        <Run Text="{Binding GpuPercentText, RelativeSource={RelativeSource AncestorType=controls:SystemHealthStrip}}"
                             FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Border>

</UserControl>
