<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:WireBound.Avalonia.ViewModels"
             xmlns:converters="using:WireBound.Avalonia.Converters"
             xmlns:controls="using:WireBound.Avalonia.Controls"
             x:Class="WireBound.Avalonia.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             Background="{StaticResource BackgroundBrush}"
             AutomationProperties.Name="History View">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="24">

            <!-- PAGE HEADER + PERIOD SELECTOR -->
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="History" Classes="PageTitle" />
                    <TextBlock Text="Browse network, system and app activity from any period" Classes="Subtitle" />
                </StackPanel>

                <Border Grid.Column="1" Classes="CompactCard" Padding="14,10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Period" Classes="Caption" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <RadioButton GroupName="HistoryPeriod"
                                         IsChecked="{Binding SelectedPeriod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:InsightsPeriod.Today}}"
                                         Command="{Binding SetPeriodCommand}"
                                         CommandParameter="{x:Static vm:InsightsPeriod.Today}"
                                         Classes="segmented-option"
                                         Padding="12,8" CornerRadius="8"
                                         Background="{StaticResource SurfaceBrush}"
                                         AutomationProperties.Name="Today period">
                                <TextBlock Text="Today" FontSize="12" />
                            </RadioButton>
                            <RadioButton GroupName="HistoryPeriod"
                                         IsChecked="{Binding SelectedPeriod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:InsightsPeriod.ThisWeek}}"
                                         Command="{Binding SetPeriodCommand}"
                                         CommandParameter="{x:Static vm:InsightsPeriod.ThisWeek}"
                                         Classes="segmented-option"
                                         Padding="12,8" CornerRadius="8"
                                         Background="{StaticResource SurfaceBrush}"
                                         AutomationProperties.Name="This week period">
                                <TextBlock Text="Week" FontSize="12" />
                            </RadioButton>
                            <RadioButton GroupName="HistoryPeriod"
                                         IsChecked="{Binding SelectedPeriod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:InsightsPeriod.ThisMonth}}"
                                         Command="{Binding SetPeriodCommand}"
                                         CommandParameter="{x:Static vm:InsightsPeriod.ThisMonth}"
                                         Classes="segmented-option"
                                         Padding="12,8" CornerRadius="8"
                                         Background="{StaticResource SurfaceBrush}"
                                         AutomationProperties.Name="This month period">
                                <TextBlock Text="Month" FontSize="12" />
                            </RadioButton>
                            <RadioButton GroupName="HistoryPeriod"
                                         IsChecked="{Binding SelectedPeriod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:InsightsPeriod.Custom}}"
                                         Command="{Binding SetPeriodCommand}"
                                         CommandParameter="{x:Static vm:InsightsPeriod.Custom}"
                                         Classes="segmented-option"
                                         Padding="12,8" CornerRadius="8"
                                         Background="{StaticResource SurfaceBrush}"
                                         AutomationProperties.Name="Custom period">
                                <TextBlock Text="Custom" FontSize="12" />
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Custom date range pickers (only when Custom is selected) -->
            <Border Classes="CompactCard" Padding="14,10"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding IsCustomPeriod}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="From" Classes="Caption" VerticalAlignment="Center" />
                    <CalendarDatePicker SelectedDate="{Binding CustomStartDate}"
                                        AutomationProperties.Name="History start date" />
                    <TextBlock Text="to" Classes="Caption" VerticalAlignment="Center" />
                    <CalendarDatePicker SelectedDate="{Binding CustomEndDate}"
                                        AutomationProperties.Name="History end date" />
                </StackPanel>
            </Border>

            <!-- Loading overlay (first load only) -->
            <Border Classes="Card" Padding="40"
                    IsVisible="{Binding ShowLoadingOverlay}"
                    HorizontalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Spacing="16">
                    <ProgressBar IsIndeterminate="True" Width="200" />
                    <TextBlock Text="Loading history…" Classes="Subtitle" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Error state -->
            <Border Classes="Card" Padding="40"
                    IsVisible="{Binding HasError}"
                    HorizontalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="Couldn't load history" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ErrorMessage}" Classes="Subtitle" HorizontalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- CONTENT -->
            <StackPanel Spacing="24" IsVisible="{Binding HasData}">

                <!-- Summary cards -->
                <Grid ColumnDefinitions="*, *, *, *, *" ColumnSpacing="16">
                    <Border Grid.Column="0" Classes="CompactCard">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:WbIcon IconKey="WbMetricDownload" Width="14" Height="14" />
                                <TextBlock Text="TOTAL DOWNLOAD" Classes="MetricLabel" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalDownload}"
                                       FontSize="20" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding TotalDownload}"
                                       Foreground="{StaticResource DownloadBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="CompactCard">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:WbIcon IconKey="WbMetricUpload" Width="14" Height="14" />
                                <TextBlock Text="TOTAL UPLOAD" Classes="MetricLabel" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalUpload}"
                                       FontSize="20" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding TotalUpload}"
                                       Foreground="{StaticResource UploadBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="CompactCard">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:WbIcon IconKey="WbEntityCpu" Width="14" Height="14" />
                                <TextBlock Text="AVG CPU" Classes="MetricLabel" />
                            </StackPanel>
                            <TextBlock Text="{Binding AvgCpuPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource CpuBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Classes="CompactCard">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:WbIcon IconKey="WbEntityMemory" Width="14" Height="14" />
                                <TextBlock Text="AVG MEMORY" Classes="MetricLabel" />
                            </StackPanel>
                            <TextBlock Text="{Binding AvgMemoryPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource MemoryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Classes="CompactCard">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="💽" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="AVG DISK" Classes="MetricLabel" />
                            </StackPanel>
                            <TextBlock Text="{Binding AvgDiskActivityPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource DiskBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Network usage chart -->
                <Border Classes="Card">
                    <Grid RowDefinitions="Auto, 280" RowSpacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Network usage" Classes="SectionHeader" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding RangeLabel}" Classes="Caption" VerticalAlignment="Center" />
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding NetworkSeries}"
                                            XAxes="{Binding NetworkXAxes}"
                                            YAxes="{Binding NetworkYAxes}"
                                            ZoomMode="None"
                                            TooltipPosition="Top"
                                            LegendPosition="Top"
                                            LegendTextPaint="#A0A8B8"
                                            LegendTextSize="12"
                                            Background="{StaticResource SurfaceBrush}"
                                            AutomationProperties.Name="Network usage history chart"
                                            AutomationProperties.HelpText="Download and upload data per day for the selected period" />
                    </Grid>
                </Border>

                <!-- System resource trends chart -->
                <Border Classes="Card">
                    <Grid RowDefinitions="Auto, 280" RowSpacing="12">
                        <TextBlock Text="System resource trends" Classes="SectionHeader" />
                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding SystemSeries}"
                                            XAxes="{Binding SystemXAxes}"
                                            YAxes="{Binding SystemYAxes}"
                                            ZoomMode="None"
                                            TooltipPosition="Top"
                                            LegendPosition="Top"
                                            LegendTextPaint="#A0A8B8"
                                            LegendTextSize="12"
                                            Background="{StaticResource SurfaceBrush}"
                                            AutomationProperties.Name="System resource trends chart"
                                            AutomationProperties.HelpText="CPU, memory and disk activity over the selected period" />
                    </Grid>
                </Border>

                <!-- Top apps -->
                <Border Classes="Card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Top apps by network traffic" Classes="SectionHeader" />
                        <ItemsControl ItemsSource="{Binding TopApps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HistoryAppEntry">
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="16">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="{StaticResource BorderSubtleBrush}"
                                                    ClipToBounds="True" VerticalAlignment="Center">
                                                <Grid>
                                                    <controls:WbIcon IconKey="WbEntityApp" Width="18" Height="18"
                                                                     IsVisible="{Binding !HasIcon}" />
                                                    <Image Source="{Binding IconPath, Converter={x:Static converters:IconPathToBitmapConverter.Instance}}"
                                                           Width="24" Height="24"
                                                           Stretch="Uniform"
                                                           IsVisible="{Binding HasIcon}" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Name}" />
                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" MinWidth="90">
                                                <TextBlock Text="{Binding DownloadFormatted}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource DownloadBrush}"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding UploadFormatted}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource UploadBrush}"
                                                           HorizontalAlignment="Right" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Spacing="2" VerticalAlignment="Center" MinWidth="90">
                                                <TextBlock Text="{Binding TotalFormatted}"
                                                           FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding LocalFormatted, StringFormat='{}{0} local'}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           IsVisible="{Binding HasLocal}"
                                                           ToolTip.Tip="Loopback / localhost traffic, excluded from the network total" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Empty state -->
            <Border Classes="Card" Padding="60"
                    IsVisible="{Binding ShowEmptyState}"
                    HorizontalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <controls:WbIcon IconKey="WbMetricAnalytics" Width="48" Height="48" HorizontalAlignment="Center" />
                    <TextBlock Text="No history for this period"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Try a wider date range, or let monitoring run to collect data"
                               Classes="Subtitle" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
