<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:helpers="using:WireBound.Avalonia.Helpers"
        xmlns:controls="using:WireBound.Avalonia.Controls"
        xmlns:converters="using:WireBound.Avalonia.Converters">

    <!-- WbIcon template: render the generated raster icon directly. High-quality
         interpolation keeps the detailed icons crisp when downscaled to small UI
         sizes (14-24px). Semantic icons are recoloured to their theme brush (or the
         explicit Tint) by TintedIconConverter; others render natively. -->
    <Style Selector="controls|WbIcon">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Image Stretch="Uniform"
                       RenderOptions.BitmapInterpolationMode="HighQuality">
                    <Image.Source>
                        <MultiBinding Converter="{x:Static converters:TintedIconConverter.Instance}">
                            <Binding Path="IconKey" RelativeSource="{RelativeSource TemplatedParent}" />
                            <Binding Path="Tint" RelativeSource="{RelativeSource TemplatedParent}" />
                        </MultiBinding>
                    </Image.Source>
                </Image>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Forward mouse-wheel events from chart controls to the ancestor ScrollViewer.
         Without this the chart consumes the wheel event for zoom and the page becomes
         unscrollable while the cursor is over a chart. -->
    <Style Selector="lvc|CartesianChart">
        <Setter Property="helpers:WheelScrollForwarder.ForwardToScrollViewer" Value="True" />
    </Style>
    <Style Selector="lvc|PieChart">
        <Setter Property="helpers:WheelScrollForwarder.ForwardToScrollViewer" Value="True" />
    </Style>

    <!-- 
    ═══════════════════════════════════════════════════════════════════════════
    WireBound Design System v2.0 - Component Styles (Avalonia)
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CARD STYLES                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="BoxShadow" Value="0 4 20 0 #4D000000" />
    </Style>
    
    <Style Selector="Border.ElevatedCard">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="BoxShadow" Value="0 8 30 0 #66000000" />
    </Style>
    
    <Style Selector="Border.CompactCard">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BoxShadow" Value="0 2 12 0 #40000000" />
    </Style>
    
    <Style Selector="Border.AccentCard">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="BoxShadow" Value="0 0 24 0 #8000E5FF" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY STYLES                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Style Selector="TextBlock.PageTitle">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>
    
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.3" />
    </Style>
    
    <Style Selector="TextBlock.CardTitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>
    
    <Style Selector="TextBlock.Subtitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
    </Style>
    
    <Style Selector="TextBlock.Caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
    </Style>
    
    <Style Selector="TextBlock.MetricLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    
    <Style Selector="TextBlock.HeroSpeed">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    
    <Style Selector="TextBlock.LargeMetric">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>
    
    <Style Selector="TextBlock.MediumMetric">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>

    <!-- Default TextBlock style -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BUTTON STYLES                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource ButtonHoverColor}" />
    </Style>
    
    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="{StaticResource SecondaryButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="Button.Warning">
        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="Button.Accent">
        <Setter Property="Background" Value="{StaticResource AccentBgTintBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.Accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource BackgroundBrush}" />
    </Style>
    
    <Style Selector="Button.Ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FILTER CHIPS: pill-shaped buttons used for stateful scoping controls -->
    <!-- (date range presets, sort presets, etc.). The .active class signals -->
    <!-- which option is currently chosen — fixes the "looks like flat text" -->
    <!-- problem on AppsView where users couldn't tell which range was on.   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.FilterChip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.FilterChip /template/ ContentPresenter">
        <Setter Property="CornerRadius" Value="999" />
    </Style>
    <Style Selector="Button.FilterChip:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SelectionBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.FilterChip.active">
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.FilterChip.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentBgTintBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TOOLBAR BUTTONS: compact controls for toolbar rows where Primary    -->
    <!-- chrome would dominate the controls it sits next to. Combine with a  -->
    <!-- semantic class: `Classes="Secondary ToolbarButton"`.                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.ToolbarButton">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SUBTLE CARD: a quieter surface for secondary toolbars / filter      -->
    <!-- strips so they don't compete visually with the primary card above.  -->
    <!-- Same corner + border treatment as Card, no shadow, slightly lower   -->
    <!-- contrast border so it reads as "context for the row above."         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Border.SubtleCard">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- INPUT STYLES                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Date pickers: match the themed input treatment (surface fill, themed
         border, 8px radius, 40px height) so they sit on the same baseline as
         the search box and combo boxes in toolbar rows instead of rendering
         with the default Fluent chrome. -->
    <Style Selector="CalendarDatePicker">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
    </Style>

    <!-- Override the Fluent template's pointer-over / focused backgrounds + borders.
         Without these the inner PART_BorderElement shows the system accent (orange
         on Windows light/contrast themes) regardless of our outer BorderBrush. -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="ToggleSwitch">
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- NAVIGATION STYLES                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="ListBoxItem.NavItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="ListBoxItem.NavItem:pointerover">
        <Setter Property="Background" Value="{StaticResource FlyoutItemHoverBrush}" />
    </Style>
    
    <Style Selector="ListBoxItem.NavItem:selected">
        <Setter Property="Background" Value="{StaticResource FlyoutItemActiveColor}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DIVIDER STYLES                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Style Selector="Rectangle.Divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Fill" Value="{StaticResource DividerBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    
    <Style Selector="Rectangle.VerticalDivider">
        <Setter Property="Width" Value="1" />
        <Setter Property="Fill" Value="{StaticResource DividerBrush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STATUS INDICATOR STYLES                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Style Selector="Ellipse.StatusDot">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SCROLLVIEWER STYLES                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Style Selector="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>

</Styles>
